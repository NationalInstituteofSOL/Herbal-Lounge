              <select id="f-ptime"><option>Today · within 1 hour</option><option>Today · 2–4pm</option><option>Today · 4–6pm</option><option>Tomorrow morning</option></select>
            </div>
            <div class="field" style="font-size:.84rem;color:var(--ink-soft)">Collect at the apothecary counter — we'll text you when it's ready.</div>
          </div>

          <div class="conditional" id="cond-curbside">
            <div class="field-2">
              <div class="field"><label>Vehicle make &amp; color</label><input id="f-vehicle" placeholder="Silver Honda CR-V" /></div>
              <div class="field"><label>Arrival time</label>
                <select id="f-ctime"><option>I'm on my way (~15 min)</option><option>Within the hour</option><option>This afternoon</option></select>
              </div>
            </div>
            <div class="field" style="font-size:.84rem;color:var(--ink-soft)">Park in a curbside spot and we'll bring your order out to you.</div>
          </div>
        </fieldset>

        <fieldset>
          <legend>Your details</legend>
          <div class="field-2">
            <div class="field"><label>First name</label><input id="f-first" placeholder="First" /></div>
            <div class="field"><label>Last name</label><input id="f-last" placeholder="Last" /></div>
          </div>
          <div class="field-2">
            <div class="field"><label>Email</label><input id="f-email" type="email" placeholder="you@email.com" /></div>
            <div class="field"><label>Mobile (for order texts)</label><input id="f-phone" type="tel" placeholder="(555) 123-4567" /></div>
          </div>
        </fieldset>

        <fieldset>
          <legend>Payment</legend>
          <div id="pay-area"></div>
        </fieldset>
      </div>

      <div id="summaryCol"></div>
    </div>`;
  setFulfillment(fulfillment);
  renderSummary();
  mountPayment();
}

function renderSummary(){
  const col = document.getElementById('summaryCol');
  if(!col) return;
  const f = fees();
  const items = cartList();
  col.innerHTML = `
    <div class="summary">
      <h3>Order summary</h3>
      ${items.map(i=>`<div class="sum-item"><span><span class="q">${i.qty}×</span>${i.name}</span><span>$${(i.price*i.qty).toFixed(2)}</span></div>`).join('')}
      <div class="sum-item" style="border:none"><span>Subtotal</span><span>$${f.sub.toFixed(2)}</span></div>
      <div class="sum-item" style="border:none"><span>${fulfillment==='delivery'?'Delivery':'Pickup / curbside'}</span><span>${fulfillment==='delivery'?(f.delivery===0?'Free':'$'+f.delivery.toFixed(2)):'Free'}</span></div>
      <div class="sum-item" style="border:none"><span>Tax (${(TAX_RATE*100).toFixed(0)}%)</span><span>$${f.tax.toFixed(2)}</span></div>
      <div class="sum-item" style="border-top:1px solid var(--line);border-bottom:none;font-weight:700;font-size:1.05rem;color:var(--ink);padding-top:12px"><span>Total</span><span>$${f.total.toFixed(2)}</span></div>
      <button class="place-btn" id="placeBtn" onclick="placeOrder()">Pay $${f.total.toFixed(2)}</button>
      <div class="err" id="payErr"></div>
      <div class="pay-note">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#9b8038" stroke-width="1.8" style="flex:none;margin-top:1px"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Secured by Square. Your card details are encrypted and never touch our servers.
      </div>
    </div>`;
}

/* ===== Square Web Payments SDK ===== */
let squareCard = null;
let squareReady = false;

async function mountPayment(){
  const area = document.getElementById('pay-area');
  const live = SQUARE.appId && SQUARE.locationId;
  if(!live){ renderDemoCard(area); return; }
  area.innerHTML = `<div id="card-container"></div>`;
  try{
    await loadSquareSdk();
    const payments = window.Square.payments(SQUARE.appId, SQUARE.locationId);
    squareCard = await payments.card();
    await squareCard.attach('#card-container');
    squareReady = true;
  }catch(e){
    console.warn('Square SDK unavailable, falling back to demo:', e);
    renderDemoCard(area);
  }
}
function loadSquareSdk(){
  return new Promise((resolve,reject)=>{
    if(window.Square) return resolve();
    const sandbox = SQUARE.appId.startsWith('sandbox-');
    const s = document.createElement('script');
    s.src = sandbox ? 'https://sandbox.web.squarecdn.com/v1/square.js' : 'https://web.squarecdn.com/v1/square.js';
    s.onload = ()=> window.Square ? resolve() : reject(new Error('Square not found'));
    s.onerror = ()=> reject(new Error('Failed to load Square SDK'));
    document.head.appendChild(s);
    setTimeout(()=>{ if(!window.Square) reject(new Error('Square load timeout')); }, 6000);
  });
}
function renderDemoCard(area){
  squareReady = false;
  area.innerHTML = `
    <div class="demo-banner">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7a6420" stroke-width="2" style="flex:none;margin-top:1px"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <span><b>Demo mode.</b> No real payment is taken. Add your Square keys in <code>index.html</code> to accept live cards.</span>
    </div>
    <div class="demo-card">
      <div class="field"><label>Card number</label><input id="d-card" placeholder="4242 4242 4242 4242" inputmode="numeric" /></div>
      <div class="field-2">
        <div class="field"><label>Expiry</label><input id="d-exp" placeholder="MM / YY" /></div>
        <div class="field"><label>CVV</label><input id="d-cvv" placeholder="123" inputmode="numeric" /></div>
      </div>
    </div>`;
}

/* ===== Place order ===== */
function val(id){ const el=document.getElementById(id); return el?el.value.trim():''; }

function validate(){
  const err = document.getElementById('payErr');
  if(!val('f-first')||!val('f-last')) return setErr('Please enter your name.');
  if(!/^[^@]+@[^@]+\.[^@]+$/.test(val('f-email'))) return setErr('Please enter a valid email.');
  if(!val('f-phone')) return setErr('Please add a mobile number for order updates.');
  if(fulfillment==='delivery' && (!val('f-address')||!val('f-zip'))) return setErr('Please add your delivery address and ZIP.');
  if(fulfillment==='curbside' && !val('f-vehicle')) return setErr('Please describe your vehicle for curbside.');
  err.textContent=''; return true;
}
function setErr(m){ document.getElementById('payErr').textContent=m; return false; }

async function placeOrder(){
  if(!validate()) return;
  const btn = document.getElementById('placeBtn');
  const f = fees();
  btn.disabled = true; btn.textContent = 'Processing…';

  const order = collectOrder(f);

  try{
    if(squareReady && squareCard){
      // ---- LIVE: tokenize card and send to backend (server.js -> CreatePayment) ----
      const result = await squareCard.tokenize();
      if(result.status !== 'OK') throw new Error(result.errors?.[0]?.message || 'Card could not be verified.');
      const res = await fetch(SQUARE.paymentUrl, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ sourceId: result.token, amountCents: Math.round(f.total*100), currency: SQUARE.currency, order })
      });
      const data = await res.json();
      if(!res.ok || !data.success) throw new Error(data.error || 'Payment was declined.');
      showConfirmation(data.orderNumber || order.number, order, f);
    }else{
      // ---- DEMO: simulate a successful payment ----
      await new Promise(r=>setTimeout(r,1100));
      showConfirmation(order.number, order, f);
    }
  }catch(e){
    btn.disabled=false; btn.textContent=`Pay $${f.total.toFixed(2)}`;
    setErr(e.message || 'Something went wrong. Please try again.');
  }
}

function collectOrder(f){
  return {
    number: 'DT-' + Math.random().toString(36).slice(2,7).toUpperCase(),
    fulfillment,
    customer:{ first:val('f-first'), last:val('f-last'), email:val('f-email'), phone:val('f-phone') },
    delivery: fulfillment==='delivery' ? {address:val('f-address'), city:val('f-city'), zip:val('f-zip'), notes:val('f-dnotes')} : null,
    pickup: fulfillment==='pickup' ? {time:val('f-ptime')} : null,
    curbside: fulfillment==='curbside' ? {vehicle:val('f-vehicle'), time:val('f-ctime')} : null,
    items: cartList().map(i=>({id:i.id,name:i.name,qty:i.qty,price:i.price})),
    totals: f
  };
}

function fulfillmentLine(o){
  if(o.fulfillment==='delivery') return `Delivery to ${o.delivery.address}, ${o.delivery.city||''} ${o.delivery.zip} — we'll text you a window shortly.`;
  if(o.fulfillment==='pickup')  return `Pickup — ${o.pickup.time}. We'll text ${o.customer.phone} when it's ready at the counter.`;
  return `Curbside — ${o.curbside.vehicle} (${o.curbside.time}). Pull into a curbside spot and we'll bring it out.`;
}

function showConfirmation(number, o, f){
  const body = document.getElementById('checkoutBody');
  cart = {}; updateCount(); renderCart();
  body.innerHTML = `
    <div class="confirm">
      <div class="check"><svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
      <p class="eyebrow">Order confirmed</p>
      <h2>Thank you, ${o.customer.first}.</h2>
      <p style="color:var(--ink-soft)">Your order <span class="ordno">${number}</span> is in good hands. A receipt is on its way to ${o.customer.email}.</p>
      <div class="confirm-card">
        <div style="font-weight:700;color:var(--herb);margin-bottom:8px;font-family:var(--display);font-size:1.15rem">What's next</div>
        <p style="font-size:.92rem;color:var(--ink-soft);margin:0 0 16px">${fulfillmentLine(o)}</p>
        ${o.items.map(i=>`<div class="sum-item"><span><span class="q">${i.qty}×</span>${i.name}</span><span>$${(i.price*i.qty).toFixed(2)}</span></div>`).join('')}
        <div class="sum-item" style="border-top:1px solid var(--line);border-bottom:none;font-weight:700;color:var(--ink);padding-top:12px"><span>Total paid</span><span>$${f.total.toFixed(2)}</span></div>
      </div>
      <button class="btn btn-gold" onclick="closeCheckout()">Continue shopping</button>
    </div>`;
  window.scrollTo(0,0);
}

/* ===== Keyboard ===== */
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){ closeCart(); }
});

/* ===== Init ===== */
render(); updateCount();
</script>
</body>
</html>

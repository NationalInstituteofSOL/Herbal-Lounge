function subtotal(){ return cartList().reduce((s,i)=>s+i.price*i.qty,0); }

function addToCart(id){
  cart[id] = (cart[id]||0)+1;
  updateCount(); render(); renderCart();
  const p = find(id);
  toast(`${p.name} added to cart`);
}
function changeQty(id,d){
  cart[id]=(cart[id]||0)+d;
  if(cart[id]<=0) delete cart[id];
  updateCount(); renderCart(); render();
  if(document.getElementById('checkout').classList.contains('open')) renderCheckout();
}
function removeItem(id){ delete cart[id]; updateCount(); renderCart(); render(); }
function updateCount(){ document.getElementById('cartCount').textContent = itemCount(); }


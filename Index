<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>DIVINITea — Holistic Wellness & Herbal Apothecary</title>
<meta name="description" content="Hand-blended loose-leaf herbal teas and single botanicals for everyday wellness. Delivery, pickup, and curbside available." />

<!-- Fonts (graceful system fallbacks if blocked) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
  :root{
    --herb:#1c2c22;          /* deep herb green */
    --herb-2:#243a2c;        /* lighter section green */
    --parchment:#f4efe3;     /* warm parchment */
    --parchment-2:#fbf8f1;   /* card cream */
    --gold:#bda05a;          /* gold leaf accent */
    --gold-deep:#9b8038;
    --hibiscus:#9c4a52;      /* rose/hibiscus accent */
    --ink:#23251f;           /* near-black text */
    --ink-soft:#55584d;
    --line:#e3dccb;
    --ok:#2f6b46;
    --shadow:0 18px 50px -24px rgba(28,44,34,.45);
    --radius:16px;
    --maxw:1180px;
    --display:"Fraunces",Georgia,"Times New Roman",serif;
    --body:"Inter",system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
  }

  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    margin:0;font-family:var(--body);color:var(--ink);
    background:var(--parchment);line-height:1.55;-webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,h4{font-family:var(--display);font-weight:600;line-height:1.08;margin:0;letter-spacing:-.01em}
  a{color:inherit}
  img{max-width:100%}
  button{font-family:inherit;cursor:pointer;border:none;background:none}
  .eyebrow{font-family:var(--body);font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;font-weight:600;color:var(--gold-deep)}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 22px}

  /* ===== Announcement ===== */
  .announce{background:var(--herb);color:#f2ecdd;text-align:center;font-size:.82rem;letter-spacing:.04em;padding:9px 16px}
  .announce b{color:var(--gold)}

  /* ===== Header ===== */
  header{position:sticky;top:0;z-index:40;background:rgba(244,239,227,.86);backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
  .nav{display:flex;align-items:center;gap:18px;height:68px}
  .brand{display:flex;align-items:center;gap:11px;text-decoration:none;margin-right:auto}
  .seal{width:42px;height:42px;flex:none;border-radius:50%;display:grid;place-items:center;
        background:radial-gradient(circle at 30% 25%,var(--herb-2),var(--herb));border:1.5px solid var(--gold);box-shadow:inset 0 0 0 3px rgba(189,160,90,.18)}
  .brand-name{font-family:var(--display);font-size:1.42rem;font-weight:600;letter-spacing:-.02em;color:var(--herb)}
  .brand-name span{color:var(--gold-deep)}
  .brand-sub{display:block;font-family:var(--body);font-size:.58rem;letter-spacing:.24em;text-transform:uppercase;color:var(--ink-soft);margin-top:-2px}
  .navlinks{display:flex;gap:24px}
  .navlinks a{text-decoration:none;font-size:.9rem;font-weight:500;color:var(--ink);padding:6px 0;border-bottom:2px solid transparent}
  .navlinks a:hover{border-color:var(--gold)}
  .cart-btn{display:flex;align-items:center;gap:8px;background:var(--herb);color:var(--parchment);
            padding:10px 16px;border-radius:999px;font-weight:600;font-size:.88rem;transition:transform .12s ease, background .2s}
  .cart-btn:hover{background:var(--herb-2);transform:translateY(-1px)}
  .cart-count{background:var(--gold);color:var(--herb);min-width:21px;height:21px;border-radius:999px;display:inline-grid;place-items:center;font-size:.74rem;font-weight:700;padding:0 5px}

  /* ===== Hero ===== */
  .hero{position:relative;overflow:hidden;background:
      radial-gradient(140% 120% at 85% -10%, rgba(189,160,90,.16), transparent 55%),
      linear-gradient(180deg,var(--herb) 0%, var(--herb-2) 100%);color:#f4efe3}
  .hero .wrap{display:grid;grid-template-columns:1.15fr .85fr;gap:30px;align-items:center;padding-top:64px;padding-bottom:64px}
  .hero h1{font-size:clamp(2.5rem,6vw,4.3rem);color:#f6f1e4;font-weight:600}
  .hero h1 em{font-style:italic;color:var(--gold)}
  .hero p.lead{font-size:1.06rem;color:#d9d3c2;max-width:46ch;margin:18px 0 26px}
  .hero-cta{display:flex;flex-wrap:wrap;gap:12px}
  .btn{display:inline-flex;align-items:center;gap:9px;padding:13px 22px;border-radius:999px;font-weight:600;font-size:.95rem;text-decoration:none;transition:transform .12s ease,box-shadow .2s,background .2s,color .2s}
  .btn-gold{background:var(--gold);color:var(--herb)}
  .btn-gold:hover{transform:translateY(-2px);box-shadow:0 12px 26px -12px rgba(189,160,90,.7)}
  .btn-ghost{border:1.5px solid rgba(244,239,227,.4);color:#f4efe3}
  .btn-ghost:hover{border-color:var(--gold);color:var(--gold)}
  .fulfil-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:30px}
  .fulfil-chip{display:flex;align-items:center;gap:8px;font-size:.82rem;color:#e7e1d1;background:rgba(255,255,255,.06);border:1px solid rgba(244,239,227,.16);padding:8px 14px;border-radius:999px}
  .fulfil-chip svg{flex:none}
  .hero-art{position:relative;display:grid;place-items:center;min-height:280px}
  .hero-jar{width:min(330px,80%);aspect-ratio:1/1;border-radius:50%;
    background:radial-gradient(circle at 35% 30%, rgba(189,160,90,.4), rgba(28,44,34,.2) 60%, transparent 70%);
    display:grid;place-items:center;border:1px solid rgba(189,160,90,.35)}
  .hero-jar .seal-lg{width:62%;height:62%;border-radius:50%;display:grid;place-items:center;
    background:radial-gradient(circle at 30% 25%,#2b4233,#16241b);border:2px solid var(--gold);box-shadow:inset 0 0 0 6px rgba(189,160,90,.14)}

  /* ===== Catalog controls ===== */
  .shop{padding:54px 0 70px}
  .shop-head{display:flex;justify-content:space-between;align-items:flex-end;gap:20px;flex-wrap:wrap;margin-bottom:22px}
  .shop-head h2{font-size:clamp(1.7rem,3.6vw,2.5rem);color:var(--herb)}
  .controls{display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-bottom:26px}
  .search{flex:1;min-width:200px;display:flex;align-items:center;gap:9px;background:var(--parchment-2);border:1px solid var(--line);border-radius:999px;padding:10px 16px}
  .search input{border:none;background:none;outline:none;width:100%;font-size:.95rem;color:var(--ink)}
  .chips{display:flex;gap:8px;flex-wrap:wrap}
  .chip{padding:9px 16px;border-radius:999px;border:1px solid var(--line);background:var(--parchment-2);font-size:.85rem;font-weight:600;color:var(--ink-soft);transition:.18s}
  .chip[aria-pressed="true"]{background:var(--herb);color:var(--parchment);border-color:var(--herb)}
  .chip:hover{border-color:var(--gold)}

  /* ===== Product grid ===== */
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(244px,1fr));gap:20px}
  .card{background:var(--parchment-2);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;display:flex;flex-direction:column;transition:transform .15s ease, box-shadow .25s}
  .card:hover{transform:translateY(-4px);box-shadow:var(--shadow)}
  .thumb{position:relative;aspect-ratio:5/4;display:grid;place-items:center}
  .thumb .badge{position:absolute;top:12px;left:12px;font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;font-weight:700;padding:5px 10px;border-radius:999px;color:#fff}
  .badge.best{background:var(--hibiscus)}
  .badge.sacred{background:var(--herb)}
  .badge.alchemy{background:var(--gold-deep)}
  .card-body{padding:15px 16px 17px;display:flex;flex-direction:column;gap:8px;flex:1}
  .card-cat{font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold-deep);font-weight:700}
  .card h3{font-size:1.18rem;color:var(--herb)}
  .herblist{font-size:.78rem;color:var(--ink-soft);font-weight:500}
  .card p.desc{font-size:.85rem;color:var(--ink-soft);margin:0;flex:1}
  .card-foot{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-top:6px}
  .price{font-family:var(--display);font-size:1.3rem;font-weight:600;color:var(--ink)}
  .add{background:var(--herb);color:var(--parchment);font-weight:600;font-size:.86rem;padding:9px 15px;border-radius:999px;transition:.15s}
  .add:hover{background:var(--gold);color:var(--herb)}
  .add.in{background:var(--ok);color:#fff}

  .empty{grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--ink-soft)}

  /* ===== Cart drawer ===== */
  .scrim{position:fixed;inset:0;background:rgba(20,30,24,.5);backdrop-filter:blur(2px);opacity:0;visibility:hidden;transition:.25s;z-index:50}
  .scrim.open{opacity:1;visibility:visible}
  .drawer{position:fixed;top:0;right:0;height:100%;width:min(420px,100%);background:var(--parchment);
          z-index:60;transform:translateX(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;box-shadow:-20px 0 60px -30px rgba(0,0,0,.5)}
  .drawer.open{transform:translateX(0)}
  .drawer-head{display:flex;align-items:center;justify-content:space-between;padding:20px 22px;border-bottom:1px solid var(--line)}
  .drawer-head h3{font-size:1.4rem;color:var(--herb)}
  .icon-btn{width:38px;height:38px;border-radius:50%;display:grid;place-items:center;color:var(--ink);background:transparent}
  .icon-btn:hover{background:rgba(0,0,0,.05)}
  .cart-items{flex:1;overflow-y:auto;padding:8px 22px}
  .citem{display:grid;grid-template-columns:54px 1fr auto;gap:12px;padding:15px 0;border-bottom:1px solid var(--line);align-items:center}
  .citem .mini{width:54px;height:54px;border-radius:11px;display:grid;place-items:center;overflow:hidden}
  .citem .ci-name{font-weight:600;font-size:.92rem;color:var(--herb)}
  .citem .ci-price{font-size:.82rem;color:var(--ink-soft)}
  .qty{display:inline-flex;align-items:center;gap:0;border:1px solid var(--line);border-radius:999px;overflow:hidden;margin-top:6px}
  .qty button{width:28px;height:28px;font-size:1rem;color:var(--herb);background:var(--parchment-2)}
  .qty button:hover{background:var(--gold);color:var(--herb)}
  .qty span{min-width:26px;text-align:center;font-size:.85rem;font-weight:600}
  .ci-remove{font-size:.74rem;color:var(--hibiscus);background:none;text-decoration:underline;margin-top:6px;padding:0}
  .cart-foot{padding:18px 22px 22px;border-top:1px solid var(--line);background:var(--parchment-2)}
  .row{display:flex;justify-content:space-between;font-size:.9rem;margin-bottom:7px;color:var(--ink-soft)}
  .row.total{font-size:1.12rem;font-weight:700;color:var(--ink);margin-top:8px;padding-top:10px;border-top:1px solid var(--line)}
  .checkout-btn{width:100%;background:var(--herb);color:var(--parchment);font-weight:700;padding:15px;border-radius:12px;font-size:1rem;margin-top:14px;transition:.18s}
  .checkout-btn:hover{background:var(--gold);color:var(--herb)}
  .cart-empty{text-align:center;color:var(--ink-soft);padding:60px 20px}

  /* ===== Checkout overlay ===== */
  .checkout{position:fixed;inset:0;z-index:70;background:var(--parchment);overflow-y:auto;display:none}
  .checkout.open{display:block}
  .co-top{position:sticky;top:0;background:rgba(244,239,227,.92);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);z-index:2}
  .co-top .wrap{display:flex;align-items:center;justify-content:space-between;height:62px}
  .co-back{display:flex;align-items:center;gap:8px;font-weight:600;color:var(--herb)}
  .co-grid{display:grid;grid-template-columns:1.3fr .9fr;gap:34px;padding:34px 0 70px;align-items:start}
  fieldset{border:1px solid var(--line);border-radius:var(--radius);padding:22px;margin:0 0 22px;background:var(--parchment-2)}
  legend{font-family:var(--display);font-size:1.25rem;color:var(--herb);padding:0 8px}
  .field{margin-bottom:14px}
  .field label{display:block;font-size:.8rem;font-weight:600;color:var(--ink-soft);margin-bottom:6px;letter-spacing:.02em}
  .field input,.field select,.field textarea{width:100%;padding:12px 14px;border:1px solid var(--line);border-radius:10px;font-size:.95rem;font-family:inherit;background:#fff;color:var(--ink);outline:none}
  .field input:focus,.field select:focus,.field textarea:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(189,160,90,.18)}
  .field-2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .fulfil-opts{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:6px}
  .fopt{border:1.5px solid var(--line);border-radius:12px;padding:14px 10px;text-align:center;background:#fff;transition:.15s;display:flex;flex-direction:column;align-items:center;gap:7px}
  .fopt:hover{border-color:var(--gold)}
  .fopt[aria-pressed="true"]{border-color:var(--herb);background:var(--herb);color:var(--parchment)}
  .fopt[aria-pressed="true"] .fopt-sub{color:#cfd8cd}
  .fopt strong{font-size:.92rem}
  .fopt-sub{font-size:.7rem;color:var(--ink-soft)}
  .conditional{display:none;margin-top:6px}
  .conditional.show{display:block;animation:fade .25s ease}
  @keyframes fade{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:none}}

  /* Summary card */
  .summary{position:sticky;top:84px;background:var(--parchment-2);border:1px solid var(--line);border-radius:var(--radius);padding:22px}
  .summary h3{font-size:1.3rem;color:var(--herb);margin-bottom:14px}
  .sum-item{display:flex;justify-content:space-between;gap:10px;font-size:.88rem;padding:8px 0;border-bottom:1px dashed var(--line)}
  .sum-item .q{color:var(--gold-deep);font-weight:700;margin-right:4px}
  .pay-note{font-size:.78rem;color:var(--ink-soft);margin-top:10px;display:flex;gap:7px;align-items:flex-start}
  #card-container{margin-top:8px;min-height:52px}
  .demo-card{display:grid;grid-template-columns:1fr;gap:10px}
  .demo-card .field-2{margin:0}
  .demo-banner{font-size:.76rem;background:#fff7e2;border:1px solid #ecdca0;color:#7a6420;padding:9px 12px;border-radius:9px;margin-bottom:12px;display:flex;gap:8px;align-items:flex-start}
  .place-btn{width:100%;background:var(--herb);color:var(--parchment);font-weight:700;padding:16px;border-radius:12px;font-size:1.02rem;margin-top:16px;transition:.18s}
  .place-btn:hover{background:var(--gold);color:var(--herb)}
  .place-btn:disabled{opacity:.6;cursor:not-allowed}
  .err{color:var(--hibiscus);font-size:.82rem;margin-top:10px;min-height:1em}

  /* Confirmation */
  .confirm{max-width:640px;margin:0 auto;text-align:center;padding:60px 20px}
  .confirm .check{width:78px;height:78px;border-radius:50%;background:var(--ok);display:grid;place-items:center;margin:0 auto 22px}
  .confirm h2{font-size:2.2rem;color:var(--herb);margin-bottom:8px}
  .confirm .ordno{font-weight:700;color:var(--gold-deep);letter-spacing:.05em}
  .confirm-card{background:var(--parchment-2);border:1px solid var(--line);border-radius:var(--radius);padding:22px;text-align:left;margin:26px 0}

  /* ===== Trust strip / footer ===== */
  .trust{background:var(--herb-2);color:#e7e1d1;padding:44px 0}
  .trust-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
  .trust .t h4{font-family:var(--display);color:#f4efe3;font-size:1.15rem;margin-bottom:6px}
  .trust .t p{font-size:.86rem;color:#cfc9b8;margin:0}
  .trust .t .ic{width:40px;height:40px;border-radius:50%;background:rgba(189,160,90,.18);display:grid;place-items:center;margin-bottom:12px;color:var(--gold)}

  footer{background:var(--herb);color:#d9d3c2;padding:50px 0 30px}
  .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:30px;margin-bottom:30px}
  footer h5{font-family:var(--display);color:#f4efe3;font-size:1.05rem;margin:0 0 12px;font-weight:600}
  footer a{display:block;color:#cfc9b8;text-decoration:none;font-size:.88rem;padding:4px 0}
  footer a:hover{color:var(--gold)}
  .disclaimer{border-top:1px solid rgba(244,239,227,.14);padding-top:20px;font-size:.74rem;color:#9aa494;line-height:1.6}
  details.owner{margin-top:14px}
  details.owner summary{cursor:pointer;color:var(--gold);font-size:.8rem;font-weight:600}
  details.owner code{background:rgba(0,0,0,.25);padding:2px 6px;border-radius:5px;font-size:.78rem;color:#e7e1d1}
  details.owner ol{font-size:.8rem;color:#bfc6b6;padding-left:18px;line-height:1.7}

  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--herb);color:var(--parchment);
         padding:13px 22px;border-radius:999px;font-weight:600;font-size:.9rem;box-shadow:var(--shadow);opacity:0;visibility:hidden;transition:.25s;z-index:80}
  .toast.show{opacity:1;visibility:visible;transform:translateX(-50%) translateY(0)}

  /* ===== Responsive ===== */
  @media(max-width:860px){
    .hero .wrap{grid-template-columns:1fr;padding-top:44px;padding-bottom:44px}
    .hero-art{display:none}
    .co-grid{grid-template-columns:1fr;gap:0}
    .summary{position:static;margin-top:4px}
    .navlinks{display:none}
    .foot-grid,.trust-grid{grid-template-columns:1fr;gap:20px}
  }
  @media(max-width:520px){
    .fulfil-opts{grid-template-columns:1fr}
    .field-2{grid-template-columns:1fr}
  }
  @media (prefers-reduced-motion: reduce){*{transition:none!important;animation:none!important}}
  :focus-visible{outline:2px solid var(--gold);outline-offset:2px}
</style>
</head>
<body>

<div class="announce">Free local delivery on orders over <b>$50</b> · Same-day <b>pickup &amp; curbside</b> at our apothecary</div>

<header>
  <div class="wrap nav">
    <a class="brand" href="#top" aria-label="DIVINITea home">
      <span class="seal" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#bda05a" stroke-width="1.6" stroke-linecap="round"><path d="M12 21c5-4 7-8 7-12a7 7 0 0 0-14 0c0 4 2 8 7 12Z"/><path d="M12 21V8"/><path d="M12 12c-1.6-.6-3-2-3-4"/><path d="M12 14c1.6-.6 3-2 3-4"/></svg>
      </span>
      <span>
        <span class="brand-name">DIVINI<span>Tea</span></span>
        <span class="brand-sub">Holistic Wellness · Apothecary</span>
      </span>
    </a>
    <nav class="navlinks">
      <a href="#shop" data-filter="signature">Teas</a>
      <a href="#shop" data-filter="blend">Sacred Blends</a>
      <a href="#shop" data-filter="botanical">Botanicals</a>
      <a href="#how">How it works</a>
    </nav>
    <button class="cart-btn" onclick="openCart()" aria-label="Open cart">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.6 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
      Cart <span class="cart-count" id="cartCount">0</span>
    </button>
  </div>
</header>

<main id="top">
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-copy">
        <p class="eyebrow" style="color:var(--gold)">Hand-blended · Loose leaf · Small batch</p>
        <h1>Sacred blends,<br/>brewed with <em>intention.</em></h1>
        <p class="lead">Herbal teas and single botanicals crafted for everyday wellness — from everyday cups to our signature DIVINITea Sacred Blends.</p>
        <div class="hero-cta">
          <a href="#shop" class="btn btn-gold">Shop the teas
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="#how" class="btn btn-ghost">Pickup &amp; delivery</a>
        </div>
        <div class="fulfil-row">
          <span class="fulfil-chip"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#bda05a" stroke-width="1.8"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2"/><circle cx="18.5" cy="18.5" r="2"/></svg>Delivery</span>
          <span class="fulfil-chip"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#bda05a" stroke-width="1.8"><path d="M3 9h18M3 9l2-5h14l2 5M5 9v11h14V9"/></svg>In-store pickup</span>
          <span class="fulfil-chip"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#bda05a" stroke-width="1.8"><path d="M5 11l1.5-4.5A2 2 0 0 1 8.4 5h7.2a2 2 0 0 1 1.9 1.5L19 11"/><path d="M5 11h14v5H5z"/><circle cx="7.5" cy="16.5" r="1"/><circle cx="16.5" cy="16.5" r="1"/></svg>Curbside</span>
        </div>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>DIVINITea — Owner Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
  :root{
    --herb:#1c2c22;--herb-2:#243a2c;--parchment:#f4efe3;--parchment-2:#fbf8f1;
    --gold:#bda05a;--gold-deep:#9b8038;--hibiscus:#9c4a52;--ink:#23251f;--ink-soft:#55584d;
    --line:#e3dccb;--ok:#2f6b46;--radius:16px;
    --display:"Fraunces",Georgia,serif;--body:"Inter",system-ui,-apple-system,sans-serif;
  }
  *{box-sizing:border-box}
  body{margin:0;font-family:var(--body);color:var(--ink);background:var(--parchment);line-height:1.5}
  h1,h2,h3{font-family:var(--display);margin:0;letter-spacing:-.01em;color:var(--herb)}
  button{font-family:inherit;cursor:pointer;border:none}
  .seal{width:40px;height:40px;border-radius:50%;display:grid;place-items:center;
        background:radial-gradient(circle at 30% 25%,var(--herb-2),var(--herb));border:1.5px solid var(--gold)}

  /* Login */
  .login-wrap{min-height:100vh;display:grid;place-items:center;padding:24px;
    background:radial-gradient(140% 120% at 80% -10%, rgba(189,160,90,.18), transparent 55%),linear-gradient(180deg,var(--herb),var(--herb-2))}
  .login{width:min(400px,100%);background:var(--parchment-2);border-radius:20px;padding:34px;box-shadow:0 30px 70px -30px rgba(0,0,0,.6)}
  .login .brandrow{display:flex;align-items:center;gap:11px;margin-bottom:6px}
  .brand-name{font-family:var(--display);font-size:1.4rem;font-weight:600;color:var(--herb)}
  .brand-name span{color:var(--gold-deep)}
  .login p.sub{color:var(--ink-soft);font-size:.9rem;margin:0 0 22px}
  .field{margin-bottom:14px}
  .field label{display:block;font-size:.8rem;font-weight:600;color:var(--ink-soft);margin-bottom:6px}
  .field input{width:100%;padding:12px 14px;border:1px solid var(--line);border-radius:10px;font-size:.95rem;font-family:inherit;outline:none;background:#fff}
  .field input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(189,160,90,.18)}
  .btn{width:100%;background:var(--herb);color:var(--parchment);font-weight:700;padding:14px;border-radius:11px;font-size:1rem;transition:.18s}
  .btn:hover{background:var(--gold);color:var(--herb)}
  .btn:disabled{opacity:.6;cursor:not-allowed}
  .err{color:var(--hibiscus);font-size:.85rem;margin-top:12px;min-height:1em}

  /* App */
  .app{display:none}
  .app.on{display:block}
  .topbar{position:sticky;top:0;z-index:5;background:rgba(244,239,227,.9);backdrop-filter:blur(8px);border-bottom:1px solid var(--line)}
  .topbar .inner{max-width:1080px;margin:0 auto;padding:0 22px;height:66px;display:flex;align-items:center;gap:12px}
  .brandrow2{display:flex;align-items:center;gap:11px;margin-right:auto}
  .who{font-size:.82rem;color:var(--ink-soft)}
  .logout{background:transparent;border:1px solid var(--line);color:var(--herb);font-weight:600;font-size:.85rem;padding:8px 14px;border-radius:999px}
  .logout:hover{border-color:var(--gold)}
  .main{max-width:1080px;margin:0 auto;padding:28px 22px 70px}
  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:26px}
  .stat{background:var(--parchment-2);border:1px solid var(--line);border-radius:var(--radius);padding:18px}
  .stat .k{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold-deep);font-weight:700}
  .stat .v{font-family:var(--display);font-size:1.8rem;color:var(--herb);font-weight:600;margin-top:4px}
  .tabs{display:flex;gap:8px;margin-bottom:18px}
  .tab{padding:9px 18px;border-radius:999px;border:1px solid var(--line);background:var(--parchment-2);font-weight:600;font-size:.9rem;color:var(--ink-soft)}
  .tab[aria-selected="true"]{background:var(--herb);color:var(--parchment);border-color:var(--herb)}
  .panel{display:none}
  .panel.on{display:block}

  .order{background:var(--parchment-2);border:1px solid var(--line);border-radius:var(--radius);padding:18px 20px;margin-bottom:14px}
  .order-head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap}
  .order-no{font-family:var(--display);font-size:1.15rem;color:var(--herb);font-weight:600}
  .pill{font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;font-weight:700;padding:5px 11px;border-radius:999px;color:#fff}
  .pill.delivery{background:var(--hibiscus)}.pill.pickup{background:var(--herb)}.pill.curbside{background:var(--gold-deep)}
  .order-meta{font-size:.85rem;color:var(--ink-soft);margin-top:6px}
  .order-items{margin-top:12px;border-top:1px dashed var(--line);padding-top:10px}
  .oi{display:flex;justify-content:space-between;font-size:.86rem;padding:3px 0;color:var(--ink-soft)}
  .oi .q{color:var(--gold-deep);font-weight:700;margin-right:5px}
  .order-foot{display:flex;justify-content:space-between;align-items:center;margin-top:12px;padding-top:10px;border-top:1px solid var(--line)}
  .order-total{font-weight:700;color:var(--ink)}
  .status{font-size:.74rem;color:var(--ok);font-weight:700}
  .fulfil-detail{font-size:.82rem;color:var(--ink-soft);background:#fff;border:1px solid var(--line);border-radius:10px;padding:9px 12px;margin-top:10px}

  .payout{display:flex;justify-content:space-between;align-items:center;background:var(--parchment-2);border:1px solid var(--line);border-radius:12px;padding:14px 18px;margin-bottom:10px}
  .payout .amt{font-family:var(--display);font-size:1.25rem;color:var(--herb);font-weight:600}
  .empty{text-align:center;color:var(--ink-soft);padding:50px 20px;background:var(--parchment-2);border:1px dashed var(--line);border-radius:var(--radius)}
  .note{font-size:.8rem;color:var(--ink-soft);background:#fff7e2;border:1px solid #ecdca0;color:#7a6420;padding:11px 14px;border-radius:10px;margin-bottom:18px}
  @media(max-width:640px){.stats{grid-template-columns:1fr 1fr}}
  :focus-visible{outline:2px solid var(--gold);outline-offset:2px}
</style>
</head>
<body>

<!-- LOGIN -->
<div class="login-wrap" id="loginView">
  <div class="login">
    <div class="brandrow">
      <span class="seal"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#bda05a" stroke-width="1.6" stroke-linecap="round"><path d="M12 21c5-4 7-8 7-12a7 7 0 0 0-14 0c0 4 2 8 7 12Z"/><path d="M12 21V8"/></svg></span>
      <span class="brand-name">DIVINI<span>Tea</span></span>
    </div>
    <p class="sub">Owner dashboard — sign in to view orders &amp; payouts.</p>
    <div class="field"><label>Email</label><input id="email" type="email" autocomplete="username" placeholder="you@email.com" /></div>
    <div class="field"><label>Password</label><input id="password" type="password" autocomplete="current-password" placeholder="••••••••" /></div>
    <button class="btn" id="loginBtn" onclick="login()">Sign in</button>
    <div class="err" id="loginErr"></div>
  </div>
</div>

<!-- APP -->
<div class="app" id="appView">
  <div class="topbar">
    <div class="inner">
      <div class="brandrow2">
        <span class="seal"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#bda05a" stroke-width="1.6" stroke-linecap="round"><path d="M12 21c5-4 7-8 7-12a7 7 0 0 0-14 0c0 4 2 8 7 12Z"/><path d="M12 21V8"/></svg></span>
        <span class="brand-name" style="font-size:1.2rem">DIVINI<span>Tea</span></span>
      </div>
      <span class="who" id="who"></span>
      <button class="logout" onclick="logout()">Sign out</button>
    </div>
  </div>

  <div class="main">
    <div class="stats" id="stats"></div>

    <div class="tabs" role="tablist">
      <button class="tab" role="tab" aria-selected="true" onclick="showTab('orders')">Orders</button>
      <button class="tab" role="tab" aria-selected="false" onclick="showTab('payouts')">Payouts</button>
    </div>

    <div class="panel on" id="panel-orders">
      <div id="ordersList"></div>
    </div>
    <div class="panel" id="panel-payouts">
      <div class="note">Square deposits your sales to your linked bank account automatically. This list is your settlement history.</div>
      <div id="payoutsList"></div>
    </div>
  </div>
</div>

<script>
  let token = null;
  try { token = sessionStorage.getItem("dt_token"); } catch(e){}

  function money(n){ return "$" + Number(n||0).toFixed(2); }
  function api(path){
    return fetch(path, { headers:{ Authorization:"Bearer "+token } }).then(r=>r.json());
  }

  async function login(){
    const btn=document.getElementById("loginBtn"), err=document.getElementById("loginErr");
    const email=document.getElementById("email").value.trim();
    const password=document.getElementById("password").value;
    err.textContent=""; btn.disabled=true; btn.textContent="Signing in…";
    try{
      const res=await fetch("/login",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({email,password})});
      const data=await res.json();
      if(!data.success) throw new Error(data.error||"Sign in failed.");
      token=data.token;
      try{ sessionStorage.setItem("dt_token",token); }catch(e){}
      document.getElementById("who").textContent=data.email;
      enterApp();
    }catch(e){
      err.textContent = e.message.includes("Failed to fetch")
        ? "Can't reach the server. Start it with: node server.js"
        : e.message;
      btn.disabled=false; btn.textContent="Sign in";
    }
  }

  function logout(){
    token=null; try{ sessionStorage.removeItem("dt_token"); }catch(e){}
    document.getElementById("appView").classList.remove("on");
    document.getElementById("loginView").style.display="grid";
    document.getElementById("password").value="";
  }

  function showTab(name){
    document.querySelectorAll(".tab").forEach((t,i)=>t.setAttribute("aria-selected", (i===0)===(name==="orders")));
    document.getElementById("panel-orders").classList.toggle("on", name==="orders");
    document.getElementById("panel-payouts").classList.toggle("on", name==="payouts");
  }

  async function enterApp(){
    document.getElementById("loginView").style.display="none";
    document.getElementById("appView").classList.add("on");
    loadOrders(); loadPayouts();
  }

  function fulfilDetail(o){
    if(o.fulfillment==="delivery" && o.delivery) return `Deliver to ${o.delivery.address}, ${o.delivery.city||""} ${o.delivery.zip}${o.delivery.notes?` · ${o.delivery.notes}`:""}`;
    if(o.fulfillment==="pickup" && o.pickup) return `Pickup · ${o.pickup.time}`;
    if(o.fulfillment==="curbside" && o.curbside) return `Curbside · ${o.curbside.vehicle} · ${o.curbside.time}`;
    return "";
  }

  async function loadOrders(){
    const box=document.getElementById("ordersList");
    const data=await api("/orders").catch(()=>({orders:[]}));
    const orders=data.orders||[];
    renderStats(orders);
    if(!orders.length){ box.innerHTML=`<div class="empty">No orders yet. Completed checkouts will appear here in real time.</div>`; return; }
    box.innerHTML=orders.map(o=>{
      const items=(o.items||[]).map(i=>`<div class="oi"><span><span class="q">${i.qty}×</span>${i.name}</span><span>${money(i.price*i.qty)}</span></div>`).join("");
      const total=o.totals?.total ?? 0;
      const fd=fulfilDetail(o);
      const when=o.paidAt?new Date(o.paidAt).toLocaleString():"";
      return `<div class="order">
        <div class="order-head">
          <div>
            <div class="order-no">${o.number||"—"}</div>
            <div class="order-meta">${(o.customer?.first||"")} ${(o.customer?.last||"")} · ${o.customer?.email||""} · ${o.customer?.phone||""}</div>
            <div class="order-meta">${when}</div>
          </div>
          <span class="pill ${o.fulfillment}">${o.fulfillment||""}</span>
        </div>
        ${fd?`<div class="fulfil-detail">${fd}</div>`:""}
        <div class="order-items">${items}</div>
        <div class="order-foot"><span class="status">● ${o.status||"PAID"}</span><span class="order-total">${money(total)}</span></div>
      </div>`;
    }).join("");
  }

  function renderStats(orders){
    const revenue=orders.reduce((s,o)=>s+(o.totals?.total||0),0);
    const counts={delivery:0,pickup:0,curbside:0};
    orders.forEach(o=>{ if(counts[o.fulfillment]!=null) counts[o.fulfillment]++; });
    document.getElementById("stats").innerHTML=`
      <div class="stat"><div class="k">Orders</div><div class="v">${orders.length}</div></div>
      <div class="stat"><div class="k">Revenue</div><div class="v">${money(revenue)}</div></div>
      <div class="stat"><div class="k">Delivery</div><div class="v">${counts.delivery}</div></div>
      <div class="stat"><div class="k">Pickup / Curb</div><div class="v">${counts.pickup+counts.curbside}</div></div>`;
  }

  async function loadPayouts(){
    const box=document.getElementById("payoutsList");
    const data=await api("/payouts").catch(()=>({payouts:[]}));
    const payouts=data.payouts||[];
    if(!payouts.length){ box.innerHTML=`<div class="empty">No payouts yet. Once Square settles your sales, deposits show here.</div>`; return; }
    box.innerHTML=payouts.map(p=>`
      <div class="payout">
        <div>
          <div style="font-weight:600;color:var(--herb)">${p.status||""}</div>
          <div style="font-size:.8rem;color:var(--ink-soft)">Arrives ${p.arrivalDate||"—"}</div>
        </div>
        <div class="amt">${money(p.amount)}</div>
      </div>`).join("");
  }

  // auto-resume if a session token is already present
  if(token){ enterApp(); } 
</script>
</body>
</html>
